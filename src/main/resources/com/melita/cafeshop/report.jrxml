	<parameter name="getReceipt" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<query language="sql"><![CDATA[SELECT
     customers.`id` AS customer_id,
     customers.`customer_id` AS customer_customer_id,
     customers.`prod_id` AS customer_prod_id,
     customers.`prod_name` AS customer_prod_name,
     customers.`type` AS customer_type,
     customers.`quantity` AS customer_quantity,
     customers.`price` AS customer_price,
     customers.`date` AS customer_date,
     customers.`image` AS customer_image,
     customers.`em_username` AS customer_em_username,
     receipt.`id` AS receipt_id,
     receipt.`customer_id` AS receipt_customer_id,
     receipt.`total` AS receipt_total,
     receipt.`date` AS receipt_date,
     receipt.`em_username` AS receipt_em_username
FROM
     `customers` customers INNER JOIN `receipt` receipt ON customers.`customer_id` = receipt.`customer_id`
WHERE
     receipt.customer_id = $P{getReceipt}]]></query>
	<field name="customer_id" class="java.lang.Integer">
