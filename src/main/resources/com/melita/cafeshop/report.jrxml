<jasperReport name="ReceiptReport" language="java" pageWidth="226" pageHeight="425" columnWidth="186" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="9f72c498-f2cd-4557-bdc6-daf7a8f2e2c9">
	<property name="ireport.zoom" value="2.5937424601000023"/>
